  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Expense Tracker Concurrent Load Test Plan" enabled="true">
      <stringProp name="TestPlan.comments">Stair-step load profile: add 20 users every 30 seconds until reaching 100 concurrent users.</stringProp>
